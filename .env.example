# Server Configuration
PORT=5000
NODE_ENV=development

# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=quizarena
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/quizarena

# Security Secrets (MUST be 32+ characters in production)
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
REFRESH_TOKEN_SECRET=CHANGE_ME_TO_A_DIFFERENT_SECURE_RANDOM_STRING

# Frontend URL (used for password reset links and CORS)
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Email Service (required in production)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@yourdomain.com
